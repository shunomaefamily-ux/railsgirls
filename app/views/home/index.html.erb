<h1>在庫（ホーム）</h1>

<% @people.each do |person| %>
  <h2><%= person.name %></h2>

  <% items = person.medication_items.where(active: true) %>
  <% if items.empty? %>
    <p>表示中の薬はありません</p>
  <% else %>
    <ul>
      <% items.each do |item| %>
        <% remaining = item.medication_lots.sum(:quantity_remaining) %>
        <li>
          <strong><%= item.drug_product.display_name %></strong>
          ：残量 <%= remaining %>
        </li>
      <% end %>
    </ul>
  <% end %>
<% end %>