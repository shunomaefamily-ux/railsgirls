<h1>Import 詳細</h1>

<p>ID: <%= @import.id %></p>
<p>source: <%= @import.try(:source) %></p>

<h3>raw_text</h3>
<pre style="white-space: pre-wrap;"><%= @import.raw_text %></pre>

<p><%= link_to "QR読み取りへ戻る", scan_imports_path %></p>
<p><%= link_to "ホームへ", root_path %></p>

<hr>

<h3>このImportを在庫として登録</h3>
<% unless @jahis %>
  <p style="color:red;">このQRはJAHISTC06/08ではありません（現在は登録できません）。</p>
<% end %>

<%= form_with url: register_import_path(@import), method: :post do %>
  <div>
    <label>登録者</label><br>
    <%= select_tag :person_choice,
      options_for_select(
        [["登録者（選択してください）", "", { disabled: true, selected: true }],
         ["＋ 新規Personを作成", "new"]] +
        @people.map { |p| [p.name, p.id] }
      ),
      id: "person_choice" %>
  </div>

  <div id="new_person_fields" style="display:none; margin-top: 12px;">
    <h4>新規Person</h4>
    <div>
      <label>名前（必須）</label><br>
      <%= text_field_tag "person_attributes[name]", "", placeholder: "例：太郎" %>
    </div>
  </div>

  <% if @jahis %>
    <h4 style="margin-top: 12px;">薬ごとの入庫数</h4>

    <% @jahis.drugs.each_with_index do |drug, i| %>
      <% suggestion = @usage_suggestions[i] || {} %>
      <% suggested_kind = suggestion[:usage_kind] || "regular" %>
      <% suggested_slots = suggestion[:usage_slots] || [] %>

      <div style="margin-top: 12px; padding: 10px; border: 1px solid #ddd;">
        <label><strong><%= drug[:display_name] %></strong></label><br>

        <% if @usage_texts.present? && @usage_texts[i].present? %>
          <div style="color: #555; margin: 4px 0 8px 0;">
            用法候補: <%= @usage_texts[i] %>
          </div>
        <% end %>

        <div style="margin-bottom: 8px;">
          <label>入庫数</label><br>
          <%= number_field_tag "quantities[#{i}]", @suggested_quantities[i] || 0, min: 0 %>
        </div>

        <div style="margin-top: 8px;">
          <strong>飲むタイミング</strong><br>

          <label style="margin-right: 12px;">
            <%= radio_button_tag "usage_kind_by_index[#{i}]",
                                 "regular",
                                 suggested_kind == "regular",
                                 class: "usage-kind-radio",
                                 data: { index: i } %>
            定期
          </label>

          <label>
            <%= radio_button_tag "usage_kind_by_index[#{i}]",
                                 "prn",
                                 suggested_kind == "prn",
                                 class: "usage-kind-radio",
                                 data: { index: i } %>
            頓服
          </label>
        </div>

        <div id="usage_slots_box_<%= i %>" style="margin-top: 8px; margin-left: 12px;">
          <input type="hidden" name="usage_slots_by_index[<%= i %>][]" value="" />

          <label style="margin-right: 10px;">
            <%= check_box_tag "usage_slots_by_index[#{i}][]",
                              "morning",
                              suggested_slots.include?("morning"),
                              class: "usage-slot-checkbox",
                              data: { index: i } %>
            朝
          </label>

          <label style="margin-right: 10px;">
            <%= check_box_tag "usage_slots_by_index[#{i}][]",
                              "noon",
                              suggested_slots.include?("noon"),
                              class: "usage-slot-checkbox",
                              data: { index: i } %>
            昼
          </label>

          <label>
            <%= check_box_tag "usage_slots_by_index[#{i}][]",
                              "evening",
                              suggested_slots.include?("evening"),
                              class: "usage-slot-checkbox",
                              data: { index: i } %>
            晩
          </label>
        </div>

        <div id="usage_error_<%= i %>" style="color: red; margin-top: 6px; display: none;">
          定期薬は朝・昼・晩のいずれかを選択してください
        </div>
      </div>
    <% end %>
  <% else %>
    <div style="margin-top: 12px;">
      <label>入庫数</label><br>
      <input type="number" name="quantity" value="10" min="1" />
    </div>
  <% end %>

  <div style="margin-top: 12px;">
    <%= submit_tag "在庫に登録する", id: "register_submit", disabled: true %>
  </div>
<% end %>

<script>
  (function() {
    const sel = document.getElementById("person_choice");
    const newFields = document.getElementById("new_person_fields");
    const submit = document.getElementById("register_submit");
    const newName = document.querySelector('input[name="person_attributes[name]"]');

    function personValid() {
      const v = sel.value;
      if (v && v !== "new") return true;
      if (v === "new") return newName && newName.value.trim().length > 0;
      return false;
    }

    function usageValid() {
      const radios = document.querySelectorAll(".usage-kind-radio");
      if (radios.length === 0) return true;

      const indexes = [...new Set([...radios].map(r => r.dataset.index))];
      let ok = true;

      indexes.forEach((index) => {
        const checkedKind = document.querySelector(`input[name="usage_kind_by_index[${index}]"]:checked`);
        const error = document.getElementById(`usage_error_${index}`);
        const box = document.getElementById(`usage_slots_box_${index}`);
        const slots = document.querySelectorAll(`input[name="usage_slots_by_index[${index}][]"][type="checkbox"]`);

        if (!checkedKind) {
          ok = false;
          if (error) error.style.display = "block";
          return;
        }

        if (checkedKind.value === "prn") {
          if (box) box.style.opacity = "0.5";
          slots.forEach(cb => cb.disabled = true);
          if (error) error.style.display = "none";
          return;
        }

        if (box) box.style.opacity = "1";
        slots.forEach(cb => cb.disabled = false);

        const checkedSlots = [...slots].filter(cb => cb.checked);
        const valid = checkedSlots.length > 0;

        if (!valid) ok = false;
        if (error) error.style.display = valid ? "none" : "block";
      });

      return ok;
    }

    function update() {
      const v = sel.value;
      newFields.style.display = (v === "new") ? "block" : "none";
      submit.disabled = !(personValid() && usageValid());
    }

    sel.addEventListener("change", update);
    if (newName) newName.addEventListener("input", update);

    document.querySelectorAll(".usage-kind-radio").forEach((el) => {
      el.addEventListener("change", update);
    });

    document.querySelectorAll(".usage-slot-checkbox").forEach((el) => {
      el.addEventListener("change", update);
    });

    update();
  })();
</script>