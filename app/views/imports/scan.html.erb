<h1>QR読み取り</h1>

<p>※カメラ許可が出ます。読めたら自動で保存します。</p>

<button id="start">読み取り開始</button>
<button id="stop" disabled>停止</button>

<div id="reader" style="width: 320px; max-width: 100%;"></div>
<pre id="debug" style="white-space: pre-wrap;"></pre>

<script src="https://unpkg.com/html5-qrcode"></script>
<script>
  const startBtn = document.getElementById("start");
  const stopBtn  = document.getElementById("stop");
  const debugEl  = document.getElementById("debug");
  const csrf     = document.querySelector('meta[name="csrf-token"]').content;

  let qr;
  let handled = false;

  function log(msg) {
    debugEl.textContent = msg;
  }

  startBtn.addEventListener("click", async () => {
    startBtn.disabled = true;
    stopBtn.disabled = true;
    handled = false;
    log("カメラ準備中...");

    try {
      qr = new Html5Qrcode("reader");
      const cameras = await Html5Qrcode.getCameras();

      if (!cameras || cameras.length === 0) {
        throw new Error("カメラが見つかりません");
      }

      const backCam =
        cameras.find(c => /back|rear|environment/i.test(c.label)) ||
        cameras[cameras.length - 1];

      const cameraId = backCam.id;
      if (!cameraId) {
        throw new Error("カメラが見つかりません");
      }

      stopBtn.disabled = false;

      await qr.start(
        cameraId,
        { fps: 10, qrbox: { width: 250, height: 250 } },
        async (decodedText) => {
          if (handled) return;
          handled = true;

          try {
            log("読み取り成功。保存中...");

            stopBtn.disabled = true;
            startBtn.disabled = true;

            if (qr) {
              await qr.stop();
              await qr.clear();
            }

            const res = await fetch("/imports", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                "X-CSRF-Token": csrf
              },
              body: JSON.stringify({
                raw_text: decodedText,
                source: "qr"
              })
            });

            if (!res.ok) {
              const body = await res.text();
              throw new Error("保存失敗: " + body);
            }

            const data = await res.json();
            log("保存しました。移動します…");

            setTimeout(() => {
              window.location.href = "/";
            }, 300);

          } catch (e) {
            handled = false;
            log("エラー: " + (e?.message || e));
            startBtn.disabled = false;
            stopBtn.disabled = true;
          }
        },
        () => {}
      );

      log("読み取り中...");
    } catch (e) {
      log("エラー: " + (e?.message || e));
      startBtn.disabled = false;
      stopBtn.disabled = true;
    }
  });

  stopBtn.addEventListener("click", async () => {
    if (!qr) return;

    try {
      await qr.stop();
      await qr.clear();
    } catch (e) {
      log("停止時エラー: " + (e?.message || e));
    } finally {
      handled = false;
      stopBtn.disabled = true;
      startBtn.disabled = false;
      log("停止しました。");
    }
  });
</script>