<h1>QR読み取り</h1>

<p>※カメラ許可が出ます。読めたら自動で保存します。</p>

<button id="start">読み取り開始</button>
<button id="stop" disabled>停止</button>

<div id="reader" style="width: 320px; max-width: 100%;"></div>
<pre id="debug" style="white-space: pre-wrap;"></pre>

<%= form_with model: Import.new, url: imports_path, method: :post, local: true, id: "qr-form" do |f| %>
  <%= f.hidden_field :raw_text, id: "qr_raw_text" %>
  <%= f.hidden_field :source, value: "qr" %>
<% end %>

<meta name="turbo-visit-control" content="reload">

<script src="https://unpkg.com/html5-qrcode"></script>
<script>
  (() => {
    const startBtn  = document.getElementById("start");
    const stopBtn   = document.getElementById("stop");
    const debugEl   = document.getElementById("debug");
    const formEl    = document.getElementById("qr-form");
    const rawTextEl = document.getElementById("qr_raw_text");

    let qr = null;
    let handled = false;
    let starting = false;
    let cleaningUp = false;
    let isSubmitting = false;

    function log(msg) {
      debugEl.textContent = String(msg);
      console.log("[QR]", msg);
    }

    function setIdleUi() {
      startBtn.disabled = false;
      stopBtn.disabled = true;
    }

    function setScanningUi() {
      startBtn.disabled = true;
      stopBtn.disabled = false;
    }

    function setBusyUi() {
      startBtn.disabled = true;
      stopBtn.disabled = true;
    }

    async function cleanupQr() {
      if (isSubmitting) return;
      if (!qr || cleaningUp) return;

      cleaningUp = true;

      try {
        await qr.stop();
      } catch (_) {
      }

      try {
        await qr.clear();
      } catch (_) {
      }

      qr = null;
      cleaningUp = false;
    }

    async function startScanner() {
      if (starting) return;

      starting = true;
      handled = false;
      isSubmitting = false;
      setBusyUi();
      log("カメラ準備中...");

      try {
        await cleanupQr();

        qr = new Html5Qrcode("reader");

        await qr.start(
          { facingMode: "environment" },
          {
            fps: 10,
            qrbox: { width: 250, height: 250 },
            aspectRatio: 1.0
          },
          (decodedText) => {
            if (handled) return;

            handled = true;
            isSubmitting = true;
            setBusyUi();
            log("読み取り成功。送信します...");

            rawTextEl.value = decodedText;
            formEl.submit();
          },
          () => {}
        );

        setScanningUi();
        log("読み取り中...");
      } catch (e) {
        log("エラー: " + (e?.message || e));
        await cleanupQr();
        setIdleUi();
      } finally {
        starting = false;
      }
    }

    async function stopScanner() {
      isSubmitting = false;
      setBusyUi();
      log("停止中...");

      try {
        await cleanupQr();
        handled = false;
        log("停止しました。");
      } catch (e) {
        log("停止時エラー: " + (e?.message || e));
      } finally {
        setIdleUi();
      }
    }

    startBtn.addEventListener("click", startScanner);
    stopBtn.addEventListener("click", stopScanner);

    window.addEventListener("beforeunload", () => {
      if (!isSubmitting) cleanupQr();
    });

    window.addEventListener("pagehide", () => {
      if (!isSubmitting) cleanupQr();
    });

    document.addEventListener("turbo:before-cache", () => {
      if (!isSubmitting) cleanupQr();
    });

    setIdleUi();
  })();
</script>